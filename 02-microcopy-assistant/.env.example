# Server-side only. NO VITE_ prefix — these keys must never reach the browser bundle.

# Which LLM the server uses: "anthropic" (default) or "gemini".
LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Required when LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key

# Optional: override the Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
